# MongoDB connection (Atlas or local)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/naac?retryWrites=true&w=majority

# Auth.js / NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional: allow creating HOD accounts via invite code
HOD_INVITE_CODE=

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: sha256 if your Cloudinary account enforces SHA-256 signatures only (default is sha1)
# CLOUDINARY_SIGNATURE_ALGORITHM=sha256

# Optional: public site URL for absolute links in emails/PDF footers
NEXT_PUBLIC_APP_URL=http://localhost:3000
